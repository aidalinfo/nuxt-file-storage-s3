{
	"name": "@aidalinfo/nuxt-file-storage-s3",
	"version": "0.3.2",
	"description": "Easy solution to store files in your nuxt apps. Be able to upload files from the frontend and recieve them from the backend to then save the files in your project.",
	"repository": "aidalinfo/nuxt-file-storage-s3",
	"license": "MIT",
	"type": "module",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"exports": {
		".": {
			"types": "./dist/types.d.mts",
			"import": "./dist/module.mjs"
		}
	},
	"main": "./dist/module.mjs",
	"types": "./dist/types.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"prepack": "nuxt-module-build prepare && nuxt-module-build build",
		"dev": "nuxi dev playground",
		"dev:build": "nuxi build playground",
		"dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
		"release": "npm run lint && npm run prepack && changelogen && npm publish && git push --follow-tags",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest watch"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.884.0",
		"@aws-sdk/s3-request-presigner": "^3.884.0",
		"@nuxt/kit": "^4.3.1",
		"defu": "^6.1.4",
		"pdf-lib": "^1.17.1"
	},
	"devDependencies": {
		"@nuxt/devtools": "3.2.3",
		"@nuxt/eslint-config": "^0.7.0",
		"@nuxt/module-builder": "^1.0.2",
		"@nuxt/schema": "^4.3.1",
		"@nuxt/test-utils": "^3.23.0",
		"@types/node": "^22.0.0",
		"changelogen": "^0.6.2",
		"eslint": "^9.0.0",
		"nuxt": "^4.3.1",
		"vitest": "^3.2.0"
	}
}
